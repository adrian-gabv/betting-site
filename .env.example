# Copy this file to .env and fill in values before running docker compose.

# PostgreSQL (used by docker-compose.yml)
POSTGRES_PASSWORD=changeme

# API secrets — store via dotnet user-secrets (run from repo root):
#
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" \
#     "Host=localhost;Port=5432;Database=bettingsite;Username=postgres;Password=<POSTGRES_PASSWORD>" \
#     --project API
#
#   dotnet user-secrets set "JwtSettings:TokenKey" "<random string, min 64 chars>" \
#     --project API
